<Page
    x:Class="JellyfinXbox.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}" Padding="60 40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Search" FontSize="36" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0 0 0 24" />

        <!-- Search bar -->
        <AutoSuggestBox Grid.Row="1"
                        x:Name="SearchBox"
                        Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        QueryIcon="Find"
                        PlaceholderText="Search movies, shows..."
                        FontSize="20"
                        Background="{StaticResource SurfaceTertiaryBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource TextMutedBrush}"
                        Padding="16 14" Margin="0 0 0 32" />

        <!-- Content: libraries OR results OR loading -->
        <Grid Grid.Row="2">
            <!-- Library views (when no query) -->
            <GridView x:Name="ViewsPanel"
                      ItemsSource="{x:Bind ViewModel.Views, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="View_Click"
                      Visibility="{x:Bind ViewModel.ShowViews, Mode=OneWay}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Height="160"
                                CornerRadius="12" Margin="8"
                                Background="{StaticResource SurfaceTertiaryBrush}">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center" Spacing="12">
                                <FontIcon Glyph="&#xE8F1;" FontSize="32"
                                          Foreground="{StaticResource AccentBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingRing"
                          IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                          Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{StaticResource AccentBrush}" />

            <!-- Search results -->
            <ListView x:Name="ResultsList"
                      ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="Result_Click"
                      Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="16" Padding="12 8" Margin="0 4"
                              CornerRadius="10"
                              Background="{StaticResource SurfaceTertiaryBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="80" Height="120"
                                    CornerRadius="8"
                                    Background="{StaticResource SurfaceHoverBrush}">
                                <Image Source="{Binding ., Converter={StaticResource ItemImageConverter}, ConverterParameter=200}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding Type}" FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Text="{Binding ProductionYear}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

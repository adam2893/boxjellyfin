<Page
    x:Class="JellyfinXbox.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}" Padding="60 40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <StackPanel Grid.Row="0" Spacing="24" Margin="0 0 0 32">
            <TextBlock Text="Search" FontSize="36" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <AutoSuggestBox x:Name="SearchBox"
                            Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QueryIcon="Find"
                            PlaceholderText="Search movies, shows..."
                            FontSize="20"
                            Background="{StaticResource SurfaceTertiaryBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource TextMutedBrush}"
                            Padding="16 14" />
        </StackPanel>

        <!-- Loading -->
        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Foreground="{StaticResource AccentBrush}" />

        <!-- Search results (shown when query is active) -->
        <ListView Grid.Row="1"
                  x:Name="ResultsList"
                  ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="Result_Click"
                  Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="16" Padding="12" CornerRadius="10"
                          Background="{StaticResource SurfaceTertiaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="80" Height="120"
                                CornerRadius="8" Background="{StaticResource SurfaceHoverBrush}">
                            <Image Stretch="UniformToFill" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Type}" FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="{Binding ProductionYear}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Library views (shown when no query) -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ViewsPanel"
                      Visibility="{x:Bind ViewModel.ShowViews, Mode=OneWay}">
            <GridView ItemsSource="{x:Bind ViewModel.Views, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="View_Click">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="4" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="280" Height="160" Spacing="12"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="280" Height="160"
                                    CornerRadius="12"
                                    Background="{StaticResource SurfaceTertiaryBrush}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                    <FontIcon Glyph="&#xE8F1;"
                                              FontSize="36"
                                              Foreground="{StaticResource AccentBrush}"
                                              HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>

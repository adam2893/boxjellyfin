<Page
    x:Class="JellyfinXbox.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}" Padding="60 40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <StackPanel Grid.Row="0" Spacing="24" Margin="0 0 0 32">
            <TextBlock Text="Search" FontSize="36" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <AutoSuggestBox x:Name="SearchBox"
                            Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QueryIcon="Find"
                            PlaceholderText="Search movies, shows..."
                            FontSize="20"
                            Background="{StaticResource SurfaceTertiaryBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource TextMutedBrush}"
                            Padding="16 14" />
        </StackPanel>

        <!-- Loading -->
        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Foreground="{StaticResource AccentBrush}" />

        <!-- Results -->
        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="Result_Click">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="16" Padding="12" CornerRadius="10"
                          Background="{StaticResource SurfaceTertiaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="80" Height="120"
                                CornerRadius="8" Background="{StaticResource SurfaceHoverBrush}">
                            <Image Stretch="UniformToFill" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Type}" FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="{Binding ProductionYear}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

<Page
    x:Class="JellyfinXbox.Views.MediaDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}">
        <!-- Backdrop -->
        <Image x:Name="BackdropImage"
               Stretch="UniformToFill"
               VerticalAlignment="Top" />

        <!-- Gradient overlay -->
        <Border VerticalAlignment="Stretch">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0B0B0F" Offset="0.0" />
                    <GradientStop Color="#0B0B0F00" Offset="0.15" />
                    <GradientStop Color="#0B0B0F80" Offset="0.55" />
                    <GradientStop Color="#0B0B0F" Offset="0.85" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="60 40">
            <StackPanel Spacing="40">

                <!-- Hero section -->
                <Grid RowSpacing="24" ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Poster -->
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                            Width="240" Height="360"
                            CornerRadius="16"
                            Background="{StaticResource SurfaceTertiaryBrush}">
                        <Image x:Name="PosterImage" Stretch="UniformToFill" />
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Row="0" Grid.Column="1"
                                VerticalAlignment="Bottom" Spacing="12">
                        <!-- Title -->
                        <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                                   FontSize="42" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" MaxLines="2" />

                        <!-- Meta line -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                                       FontSize="16"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.CommunityRating, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}"
                                       Visibility="{x:Bind ViewModel.CommunityRating, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                            <TextBlock Text="{x:Bind ViewModel.Runtime, Mode=OneWay}"
                                       FontSize="16"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.Runtime, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                            <Border Padding="8 4" CornerRadius="6"
                                    Background="{StaticResource SurfaceTertiaryBrush}"
                                    Visibility="{x:Bind ViewModel.OfficialRating, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Text="{x:Bind ViewModel.OfficialRating, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </StackPanel>

                        <!-- Genres -->
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Genres, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10 6" CornerRadius="6"
                                            Background="{StaticResource SurfaceTertiaryBrush}">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="1" Grid.Column="1"
                                Orientation="Horizontal" Spacing="16"
                                VerticalAlignment="Top">
                        <Button Content="&#xE768;  Play"
                                Command="{x:Bind ViewModel.PlayItemCommand}"
                                CommandParameter="{x:Bind ViewModel.Item, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                FontSize="18" FontWeight="SemiBold"
                                Padding="32 16" CornerRadius="10">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="Enter" />
                            </Button.KeyboardAccelerators>
                        </Button>
                        <Button Content="&#xE8E1;  Trailer"
                                FontSize="16"
                                Padding="24 16" CornerRadius="10"
                                Background="{StaticResource SurfaceTertiaryBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                           FontSize="16" LineHeight="28"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="900" />

                <!-- ═══════════════════════════════════════ -->
                <!--          SEASON SELECTOR                -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel Visibility="{x:Bind ViewModel.IsSeries, Mode=OneWay}" Spacing="20">
                    <TextBlock Text="Seasons" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  HorizontalScrollMode="Enabled">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Seasons, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton Content="{Binding Name}"
                                                     FontSize="15"
                                                     Padding="20 12"
                                                     CornerRadius="8"
                                                     Background="{StaticResource SurfaceTertiaryBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     GroupName="Seasons"
                                                     IsChecked="{Binding Selected, Mode=OneWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Episode list -->
                    <ListView ItemsSource="{x:Bind ViewModel.Episodes, Mode=OneWay}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="Episode_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="20" Padding="12 16"
                                      Background="{StaticResource SurfaceTertiaryBrush}"
                                      CornerRadius="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Episode number -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IndexNumber}"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Width="48" />

                                    <!-- Thumbnail -->
                                    <Border Grid.Column="1" Width="160" Height="90"
                                            CornerRadius="8"
                                            Background="{StaticResource SurfaceHoverBrush}">
                                        <Image Stretch="UniformToFill" />
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="2" />
                                        <TextBlock Text="{Binding Overview}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="2"
                                                   Opacity="0.8" />
                                    </StackPanel>

                                    <!-- Runtime -->
                                    <TextBlock Grid.Column="3"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- ═══════════════════════════════════════ -->
                <!--                CAST                      -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel Visibility="{x:Bind ViewModel.Cast.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}}"
                            Spacing="20">
                    <TextBlock Text="Cast" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  HorizontalScrollMode="Enabled">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Cast, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="20" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="100" Spacing="8">
                                        <PersonPicture DisplayName="{Binding Name}"
                                                       Width="72" Height="72" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" TextAlignment="Center" />
                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" TextAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Back button (top-left) -->
        <Button VerticalAlignment="Top" HorizontalAlignment="Left"
                Margin="20 16"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                Foreground="{StaticResource TextPrimaryBrush}"
                Padding="12" CornerRadius="8"
                Click="Back_Click">
            <FontIcon Glyph="&#xE72B;" FontSize="18" />
        </Button>
    </Grid>
</Page>

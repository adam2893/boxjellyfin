<Page
    x:Class="JellyfinXbox.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}"
          HorizontalAlignment="Center" VerticalAlignment="Center">

        <StackPanel Width="520" Spacing="16">

            <!-- Server name -->
            <TextBlock Text="{x:Bind ViewModel.ServerName, Mode=OneWay}"
                       FontSize="16"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0 0 0 8" />

            <TextBlock Text="Sign In" FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />

            <!-- Public users list -->
            <ListView x:Name="UserListView"
                      ItemsSource="{x:Bind ViewModel.PublicUsers}"
                      SelectionMode="Single" IsItemClickEnabled="True"
                      ItemClick="UserListView_ItemClick"
                      Background="Transparent"
                      SelectionChanged="UserListView_SelectionChanged"
                      MaxHeight="200" Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="16" Padding="16 12">
                            <PersonPicture DisplayName="{Binding Name}" Width="44" Height="44" />
                            <TextBlock Text="{Binding Name}" FontSize="18" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Username -->
            <TextBlock Text="Username" FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBox x:Name="UsernameBox"
                     Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="20"
                     Background="{StaticResource SurfaceTertiaryBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource TextMutedBrush}"
                     Padding="16 14" />

            <!-- Password -->
            <TextBlock Text="Password" FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <PasswordBox x:Name="PasswordBox"
                         FontSize="20"
                         Background="{StaticResource SurfaceTertiaryBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource TextMutedBrush}"
                         Padding="16 14" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                         Foreground="{StaticResource AccentBrush}" />

            <!-- Error -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       FontSize="16"
                       Foreground="{StaticResource ErrorBrush}"
                       Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" />

            <!-- Sign In -->
            <Button Content="Sign In"
                    Command="{x:Bind ViewModel.LoginCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="20" FontWeight="SemiBold"
                    HorizontalAlignment="Stretch"
                    Padding="0 16" CornerRadius="8" />

            <!-- Quick Connect -->
            <TextBlock Text="or" FontSize="14"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0 4" />

            <Button Content="Quick Connect"
                    Command="{x:Bind ViewModel.QuickConnectCommand}"
                    Background="{StaticResource SurfaceTertiaryBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontSize="18"
                    HorizontalAlignment="Stretch"
                    Padding="0 14" CornerRadius="8"
                    Visibility="{x:Bind ViewModel.IsQuickConnectEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        </StackPanel>
    </Grid>
</Page>

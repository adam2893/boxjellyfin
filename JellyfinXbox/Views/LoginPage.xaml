<Page
    x:Class="JellyfinXbox.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JellyfinXbox.Views"
    RequiresPointer="Never">

    <Grid Background="{StaticResource SurfacePrimaryBrush}">
        <StackPanel Width="560" Spacing="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0 40">

            <!-- Logo -->
            <StackPanel Spacing="8" Margin="0 0 0 24">
                <TextBlock Text="BoxJellyfin" FontSize="48" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="for Xbox" FontSize="20"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Server Name -->
            <TextBlock Text="{x:Bind ViewModel.ServerName, Mode=OneWay}"
                       FontSize="16"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{x:Bind ViewModel.ServerName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Server URL -->
            <StackPanel Spacing="8">
                <TextBlock Text="Server Address" FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBox x:Name="ServerUrlBox"
                         Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="https://your-server.com"
                         FontSize="20"
                         Background="{StaticResource SurfaceTertiaryBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource TextMutedBrush}"
                         Padding="16 14"
                         KeyDown="ServerUrlBox_KeyDown" />
            </StackPanel>

            <!-- Connect Button -->
            <Button x:Name="ConnectBtn"
                    Content="Connect"
                    Command="{x:Bind ViewModel.ConnectCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="20" FontWeight="SemiBold"
                    HorizontalAlignment="Stretch"
                    Padding="0 16"
                    CornerRadius="8" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                         Foreground="{StaticResource AccentBrush}" />

            <!-- Error -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       FontSize="16" Foreground="{StaticResource ErrorBrush}"
                       Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                       TextWrapping="Wrap" />

            <!-- Quick Connect (always available) -->
            <Grid Margin="0 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="1" Background="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="or" FontSize="14" Foreground="{StaticResource TextMutedBrush}" Padding="16 0" />
                <Border Grid.Column="2" Height="1" Background="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
            </Grid>

            <Button Content="Quick Connect"
                    Command="{x:Bind ViewModel.QuickConnectCommand}"
                    Background="{StaticResource SurfaceTertiaryBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontSize="18" FontWeight="Medium"
                    HorizontalAlignment="Stretch"
                    Padding="0 16"
                    CornerRadius="8" />

            <!-- User Selection -->
            <StackPanel x:Name="UserPanel" Spacing="16"
                        Visibility="{x:Bind ViewModel.ShowPasswordField, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListView x:Name="UserListView"
                          ItemsSource="{x:Bind ViewModel.PublicUsers}"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="UserListView_ItemClick"
                          Background="Transparent"
                          SelectionChanged="UserListView_SelectionChanged"
                          MaxHeight="240">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16"
                                        Padding="16 14">
                                <PersonPicture DisplayName="{Binding Name}"
                                               Width="48" Height="48" />
                                <TextBlock Text="{Binding Name}"
                                           FontSize="20" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Spacing="8">
                    <TextBlock Text="Username" FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBox Text="{x:Bind ViewModel.Username, Mode=TwoWay}"
                             FontSize="20"
                             Background="{StaticResource SurfaceTertiaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource TextMutedBrush}"
                             Padding="16 14" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Password" FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <PasswordBox Password="{x:Bind ViewModel.Password, Mode=TwoWay}"
                                 FontSize="20"
                                 Background="{StaticResource SurfaceTertiaryBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource TextMutedBrush}"
                                 Padding="16 14"
                                 KeyDown="PasswordBox_KeyDown" />
                </StackPanel>

                <Button Content="Sign In"
                        Command="{x:Bind ViewModel.LoginCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="20" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch"
                        Padding="0 16"
                        CornerRadius="8" />

                <Grid Margin="0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="1"
                            Background="{StaticResource TextMutedBrush}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="or" FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               Padding="16 0" />
                    <Border Grid.Column="2" Height="1"
                            Background="{StaticResource TextMutedBrush}"
                            VerticalAlignment="Center" />
                </Grid>

                <Button Content="Quick Connect"
                        Click="QuickConnect_Click"
                        Background="{StaticResource SurfaceTertiaryBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontSize="18" FontWeight="Medium"
                        HorizontalAlignment="Stretch"
                        Padding="0 16"
                        CornerRadius="8" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

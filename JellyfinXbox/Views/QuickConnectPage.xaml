<Page
    x:Class="JellyfinXbox.Views.QuickConnectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}"
          Padding="80 0"
          HorizontalAlignment="Center" VerticalAlignment="Center">

        <StackPanel Width="520" Spacing="32">

            <!-- Back button -->
            <Button Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                    Padding="12" CornerRadius="8" Click="Back_Click"
                    HorizontalAlignment="Left">
                <FontIcon Glyph="&#xE72B;" FontSize="18" />
            </Button>

            <!-- Icon + Title -->
            <StackPanel HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE8BD;" FontSize="56"
                          Foreground="{StaticResource AccentBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Quick Connect" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Link to your Jellyfin server from another device"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400" />
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--            NOT STARTED                  -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel x:Name="StartPanel" Spacing="16">
                <TextBlock Text="Open Jellyfin on your phone or another device, go to Settings → Quick Connect, and enter the code shown here."
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />

                <Button Content="Start Quick Connect"
                        Command="{x:Bind ViewModel.StartQuickConnectCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="18" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch"
                        Padding="0 14"
                        CornerRadius="8" />
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--            CONNECTING                   -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel x:Name="ConnectingPanel" Visibility="Collapsed" Spacing="24">
                <!-- Code display -->
                <Border Width="320" Height="100"
                        CornerRadius="16"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.Code, Mode=OneWay}"
                               FontSize="48" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" />

                <ProgressBar IsIndeterminate="True"
                             Foreground="{StaticResource AccentBrush}" />

                <Button Content="Cancel"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Background="{StaticResource SurfaceTertiaryBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="16"
                        Padding="24 12"
                        CornerRadius="8"
                        HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--              SUCCESS                    -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel x:Name="SuccessPanel" Visibility="Collapsed" Spacing="16"
                        HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE73E;" FontSize="48"
                          Foreground="{StaticResource SuccessBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Connected!"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource SuccessBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.ConnectedUserName, Mode=OneWay}"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--               ERROR                     -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" Spacing="16"
                        HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE783;" FontSize="48"
                          Foreground="{StaticResource ErrorBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           FontSize="14"
                           Foreground="{StaticResource ErrorBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400" />
                <Button Content="Try Again"
                        Command="{x:Bind ViewModel.StartQuickConnectCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="16"
                        Padding="24 12"
                        CornerRadius="8"
                        HorizontalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>

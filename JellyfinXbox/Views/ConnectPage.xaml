<Page
    x:Class="JellyfinXbox.Views.ConnectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}"
          HorizontalAlignment="Center" VerticalAlignment="Center">

        <StackPanel Width="520" Spacing="20">

            <!-- Logo -->
            <TextBlock Text="BoxJellyfin" FontSize="48" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center" Margin="0 0 0 12" />

            <TextBlock Text="Connect to your Jellyfin server"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />

            <!-- Server URL -->
            <TextBox x:Name="ServerUrlBox"
                     Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="https://your-server.com:8096"
                     FontSize="20"
                     Background="{StaticResource SurfaceTertiaryBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource TextMutedBrush}"
                     Padding="16 14" />

            <!-- Connect button -->
            <Button Content="Connect"
                    Command="{x:Bind ViewModel.ConnectCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="20" FontWeight="SemiBold"
                    HorizontalAlignment="Stretch"
                    Padding="0 16" CornerRadius="8" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                         Foreground="{StaticResource AccentBrush}" />

            <!-- Error message -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       FontSize="16"
                       Foreground="{StaticResource ErrorBrush}"
                       Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" />

            <!-- Server info on success -->
            <StackPanel x:Name="ServerInfoPanel"
                        Visibility="Collapsed"
                        Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE73E;" FontSize="36"
                          Foreground="{StaticResource SuccessBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.ServerName, Mode=OneWay}"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.ServerVersion, Mode=OneWay}"
                           FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Continue to login -->
            <Button x:Name="ContinueButton"
                    Content="Continue"
                    Command="{x:Bind ViewModel.ContinueCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="20" FontWeight="SemiBold"
                    HorizontalAlignment="Stretch"
                    Padding="0 16" CornerRadius="8"
                    Visibility="Collapsed" />

            <!-- Skip to Quick Connect -->
            <Button x:Name="QuickConnectButton"
                    Content="Quick Connect"
                    Command="{x:Bind ViewModel.QuickConnectCommand}"
                    Background="{StaticResource SurfaceTertiaryBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontSize="18"
                    HorizontalAlignment="Stretch"
                    Padding="0 14" CornerRadius="8"
                    Visibility="Collapsed" />

        </StackPanel>
    </Grid>
</Page>

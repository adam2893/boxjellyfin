<Page
    x:Class="JellyfinXbox.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SurfacePrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="60 40 60 0" Spacing="24">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                        Padding="12" CornerRadius="8" Click="Back_Click">
                    <FontIcon Glyph="&#xE72B;" FontSize="18" />
                </Button>
                <TextBlock Text="{x:Bind ViewModel.LibraryName, Mode=OneWay}"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Filter chips -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <RadioButton Content="All" GroupName="Filter" IsChecked="True"
                             Click="FilterAll_Click"
                             FontSize="14" Padding="16 8" CornerRadius="8"
                             Background="{StaticResource SurfaceTertiaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                <RadioButton Content="Unwatched" GroupName="Filter"
                             Click="FilterUnwatched_Click"
                             FontSize="14" Padding="16 8" CornerRadius="8"
                             Background="{StaticResource SurfaceTertiaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                <RadioButton Content="Favorites" GroupName="Filter"
                             Click="FilterFavorites_Click"
                             FontSize="14" Padding="16 8" CornerRadius="8"
                             Background="{StaticResource SurfaceTertiaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Items grid -->
        <ScrollViewer Grid.Row="1" Padding="60 24">
            <GridView x:Name="ItemsGrid"
                      ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="Item_Click">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="6"
                                       ItemWidth="180" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="160" Spacing="8">
                            <Border Width="160" Height="240"
                                    CornerRadius="12"
                                    Background="{StaticResource SurfaceTertiaryBrush}">
                                <Image Source="{Binding ., Converter={StaticResource ItemImageConverter}, ConverterParameter=300}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="2" />
                            <TextBlock Text="{Binding ProductionYear}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>

<Page
    x:Class="JellyfinXbox.Views.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Black">
        <!-- ═══════════════════════════════════════ -->
        <!--         MEDIA RENDERER                  -->
        <!-- ═══════════════════════════════════════ -->
        <MediaPlayerElement x:Name="MediaPlayerElement"
                            AutoPlay="True" />

        <!-- ═══════════════════════════════════════ -->
        <!--          LOADING OVERLAY                -->
        <!-- ═══════════════════════════════════════ -->
        <Grid x:Name="LoadingOverlay"
              Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
              Background="#99000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48"
                              Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Buffering..." FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!--       TRACK SELECTION PANEL             -->
        <!-- ═══════════════════════════════════════ -->
        <Grid x:Name="TrackPanel"
              Visibility="{x:Bind ViewModel.TrackSelection.IsVisible, Mode=OneWay}"
              HorizontalAlignment="Right" VerticalAlignment="Center"
              Width="440" Padding="0">
            <Grid.Background>
                <SolidColorBrush Color="#E6000000" />
            </Grid.Background>

            <StackPanel Padding="32" Spacing="24">
                <!-- Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Audio &amp; Subtitles" FontSize="22" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Click="CloseTrackPanel_Click"
                            Background="Transparent" Foreground="White"
                            Padding="8" CornerRadius="6">
                        <FontIcon Glyph="&#xE711;" FontSize="16" />
                    </Button>
                </Grid>

                <!-- ═══ Audio Tracks ═══ -->
                <TextBlock Text="Audio" FontSize="16" FontWeight="SemiBold"
                           Foreground="#FFFFFFCC" />
                <ListView x:Name="AudioListView"
                          ItemsSource="{x:Bind ViewModel.TrackSelection.AudioTracks}"
                          SelectionMode="Single"
                          SelectionChanged="AudioListView_SelectionChanged"
                          Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="8 12" Spacing="4">
                                <TextBlock Text="{Binding DisplayTitle}"
                                           FontSize="15" FontWeight="Medium"
                                           Foreground="White" />
                                <TextBlock Text="{Binding Codec}"
                                           FontSize="12" Foreground="#FFFFFF88" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- ═══ Subtitle Tracks ═══ -->
                <TextBlock Text="Subtitles" FontSize="16" FontWeight="SemiBold"
                           Foreground="#FFFFFFCC" />
                <ListView x:Name="SubtitleListView"
                          ItemsSource="{x:Bind ViewModel.TrackSelection.SubtitleTracks}"
                          SelectionMode="Single"
                          SelectionChanged="SubtitleListView_SelectionChanged"
                          Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="8 12" Spacing="4">
                                <TextBlock Text="{Binding DisplayTitle}"
                                           FontSize="15" FontWeight="Medium"
                                           Foreground="White" />
                                <TextBlock Text="{Binding Codec}"
                                           FontSize="12" Foreground="#FFFFFF88" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!--          TRANSPORT CONTROLS             -->
        <!-- ═══════════════════════════════════════ -->
        <Grid x:Name="TransportOverlay"
              VerticalAlignment="Bottom"
              Padding="60 24">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0.0" />
                    <GradientStop Color="#99000000" Offset="0.5" />
                    <GradientStop Color="#E6000000" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Spacing="16">
                <!-- Title -->
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="White" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                           FontSize="14" Foreground="#FFFFFFAA"
                           Visibility="{x:Bind ViewModel.Subtitle, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

                <!-- Seek bar -->
                <Slider x:Name="SeekSlider"
                        MinWidth="600"
                        Value="{x:Bind ViewModel.Position.TotalSeconds, Mode=OneWay}"
                        Maximum="{x:Bind ViewModel.Duration.TotalSeconds, Mode=OneWay}"
                        ThumbToolTipValueConverter="{StaticResource TimeSpanConverter}"
                        Foreground="{StaticResource AccentBrush}" />

                <!-- Time + controls + info -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.PositionDisplay, Mode=OneWay}"
                               FontSize="13" Foreground="#FFFFFFCC"
                               VerticalAlignment="Center" />

                    <!-- Transport buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" Spacing="8">
                        <Button Click="SeekBack_Click" Background="Transparent"
                                Foreground="White" Padding="12" CornerRadius="8">
                            <FontIcon Glyph="&#xE71F;" FontSize="20" />
                        </Button>
                        <Button Click="Rewind_Click" Background="Transparent"
                                Foreground="White" Padding="12" CornerRadius="8">
                            <FontIcon Glyph="&#xE892;" FontSize="20" />
                        </Button>
                        <Button Click="PlayPause_Click" Background="Transparent"
                                Foreground="White" Padding="16" CornerRadius="8">
                            <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="32" />
                        </Button>
                        <Button Click="Forward_Click" Background="Transparent"
                                Foreground="White" Padding="12" CornerRadius="8">
                            <FontIcon Glyph="&#xE893;" FontSize="20" />
                        </Button>
                        <Button Click="SeekForward_Click" Background="Transparent"
                                Foreground="White" Padding="12" CornerRadius="8">
                            <FontIcon Glyph="&#xE720;" FontSize="20" />
                        </Button>

                        <!-- Track selection toggle -->
                        <Border Width="1" Background="#40FFFFFF" Margin="8 4" />

                        <Button Click="ToggleTrackPanel_Click" Background="Transparent"
                                Foreground="White" Padding="12" CornerRadius="8"
                                ToolTipService.ToolTip="Audio &amp; Subtitles">
                            <FontIcon Glyph="&#xEDC4;" FontSize="20" />
                        </Button>
                    </StackPanel>

                    <!-- Codec info badges -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                Spacing="12" VerticalAlignment="Center">
                        <Border Padding="8 4" CornerRadius="6" Background="#40FFFFFF"
                                Visibility="{x:Bind ViewModel.IsDirectPlay, Mode=OneWay}">
                            <TextBlock Text="Direct Play" FontSize="11"
                                       Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                        </Border>
                        <Border Padding="8 4" CornerRadius="6" Background="#40FFFFFF"
                                Visibility="{x:Bind ViewModel.IsHdr, Mode=OneWay}">
                            <TextBlock Text="HDR" FontSize="11"
                                       Foreground="#F472B6" FontWeight="SemiBold" />
                        </Border>
                        <Border Padding="8 4" CornerRadius="6" Background="#40FFFFFF">
                            <TextBlock Text="{x:Bind ViewModel.CurrentVideoCodec, Mode=OneWay}"
                                       FontSize="11" Foreground="White" FontWeight="Medium" />
                        </Border>
                        <Border Padding="8 4" CornerRadius="6" Background="#40FFFFFF">
                            <TextBlock Text="{x:Bind ViewModel.CurrentAudioCodec, Mode=OneWay}"
                                       FontSize="11" Foreground="White" FontWeight="Medium" />
                        </Border>
                        <Border Padding="8 4" CornerRadius="6" Background="#40FFFFFF"
                                Visibility="{x:Bind ViewModel.CurrentResolution, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{x:Bind ViewModel.CurrentResolution, Mode=OneWay}"
                                       FontSize="11" Foreground="White" />
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!--           TOP INFO BAR                  -->
        <!-- ═══════════════════════════════════════ -->
        <Grid VerticalAlignment="Top" Padding="60 24">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E6000000" Offset="0.0" />
                    <GradientStop Color="#99000000" Offset="0.5" />
                    <GradientStop Color="Transparent" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="Back_Click" Background="Transparent"
                    Foreground="White" Padding="12" CornerRadius="8">
                <FontIcon Glyph="&#xE72B;" FontSize="20" />
            </Button>
        </Grid>
    </Grid>
</Page>

<Page
    x:Class="JellyfinXbox.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:JellyfinXbox.Views">

    <!-- Info row template for server details -->
    <Page.Resources>
        <Style TargetType="views:InfoRow">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="views:InfoRow">
                        <Grid Margin="0 4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{TemplateBinding Label}"
                                       FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Grid.Column="1" Text="{TemplateBinding Value}"
                                       FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>


    <ScrollViewer Background="{StaticResource SurfacePrimaryBrush}"
                  VerticalScrollBarVisibility="Hidden"
                  Padding="60 40">
        <StackPanel Spacing="48" MaxWidth="900">

            <!-- ═══════════════════════════════════════ -->
            <!--              HEADER                     -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                        Padding="12" CornerRadius="8" Click="Back_Click">
                    <FontIcon Glyph="&#xE72B;" FontSize="18" />
                </Button>
                <TextBlock Text="Settings" FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--           STREAMING QUALITY             -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel Spacing="20">
                <TextBlock Text="Streaming Quality" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <StackPanel Spacing="8">
                    <TextBlock Text="Max Streaming Bitrate" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap">
                        Lower the quality if your connection can't keep up. The player will transcode at this bitrate.
                    </TextBlock>
                    <ComboBox x:Name="BitrateComboBox"
                              ItemsSource="{x:Bind ViewModel.BitrateLabels}"
                              SelectedIndex="{x:Bind ViewModel.SelectedBitrateIndex, Mode=TwoWay}"
                              FontSize="16"
                              Background="{StaticResource SurfaceTertiaryBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              HorizontalAlignment="Stretch"
                              Padding="16 12" />
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--             SUBTITLES                    -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel Spacing="20">
                <TextBlock Text="Subtitles" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <StackPanel Spacing="16">
                    <!-- Subtitle Mode -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Default Subtitle Mode" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <ComboBox ItemsSource="{x:Bind ViewModel.SubtitleModes}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedSubtitleModeIndex, Mode=TwoWay}"
                                  FontSize="16"
                                  Background="{StaticResource SurfaceTertiaryBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HorizontalAlignment="Stretch"
                                  Padding="16 12" />
                    </StackPanel>

                    <!-- Font Size -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Subtitle Size" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Minimum="50" Maximum="200" Value="{x:Bind ViewModel.SubtitleFontSize, Mode=TwoWay}"
                                StepFrequency="10"
                                TickFrequency="25"
                                TickPlacement="BottomRight"
                                Foreground="{StaticResource AccentBrush}"
                                Header="{x:Bind ViewModel.SubtitleFontSize, Mode=OneWay}" />
                    </StackPanel>

                    <!-- Prefer Foreign -->
                    <ToggleSwitch Header="Prefer subtitles with foreign audio only"
                                  IsOn="{x:Bind ViewModel.PreferForeignSubtitles, Mode=TwoWay}"
                                  FontSize="14"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  OnContent="" OffContent="" />
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--              PLAYBACK                    -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel Spacing="20">
                <TextBlock Text="Playback" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <ToggleSwitch Header="Auto-play next episode"
                              IsOn="{x:Bind ViewModel.AutoPlayNextEpisode, Mode=TwoWay}"
                              FontSize="14"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              OnContent="" OffContent="" />
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--             SERVER INFO                  -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel Spacing="20">
                <TextBlock Text="Server" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <StackPanel Spacing="12" Padding="20"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="12">
                    <views:InfoRow Label="Server" Value="{x:Bind ViewModel.ServerName}" />
                    <views:InfoRow Label="Version" Value="{x:Bind ViewModel.ServerVersion}" />
                    <views:InfoRow Label="URL" Value="{x:Bind ViewModel.ServerUrl}" />
                    <views:InfoRow Label="User" Value="{x:Bind ViewModel.UserName}" />
                    <views:InfoRow Label="Client" Value="{x:Bind ViewModel.ClientVersion}" />
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!--              ACTIONS                     -->
            <!-- ═══════════════════════════════════════ -->
            <StackPanel Spacing="16">
                <Button Content="Sign Out"
                        Command="{x:Bind ViewModel.LogoutCommand}"
                        Background="#3D1010"
                        Foreground="{StaticResource ErrorBrush}"
                        FontSize="16"
                        Padding="24 14"
                        CornerRadius="10"
                        HorizontalAlignment="Stretch" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

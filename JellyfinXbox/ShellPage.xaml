<Page
    x:Class="JellyfinXbox.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required"
    RequiresPointer="Never"
    XYFocusKeyboardNavigation="Enabled">

    <Grid Background="{StaticResource SurfacePrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDE NAV BAR -->
        <Grid Grid.Column="0"
              Background="{StaticResource SurfaceSecondaryBrush}"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top nav -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" Spacing="32"
                        Padding="0 80">
                <TextBlock Text="J" FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center" Margin="0 0 0 16" />
                <TextBlock Text="BoxJellyfin" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0 0 0 32" />

                <Button x:Name="NavHome" Tag="home"
                        Click="NavButton_Click"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="16" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch" Padding="0 12">
                    Home
                </Button>
                <Button x:Name="NavSearch" Tag="search"
                        Click="NavButton_Click"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="16" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch" Padding="0 12">
                    Search
                </Button>
            </StackPanel>

            <!-- Bottom nav -->
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Spacing="32"
                        Padding="0 0 0 80">
                <Button x:Name="NavQuickConnect" Tag="quickconnect"
                        Click="NavButton_Click"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="14" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch" Padding="0 12">
                    Connect
                </Button>
                <Button x:Name="NavSettings" Tag="settings"
                        Click="NavButton_Click"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="14" FontWeight="SemiBold"
                        HorizontalAlignment="Stretch" Padding="0 12">
                    Settings
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content area - fills remaining space -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               Navigated="ContentFrame_Navigated" />
    </Grid>
</Page>
